{
  "name": "claude-flow",
  "version": "1.0.0",
  "description": "Claude Flow - AI agent orchestration CLI and SDK",
  "main": "dist-cjs/src/services/mcp-integration.js",
  "bin": {
    "claude-flow": "bin/claude-flow.js"
  },
  "exports": {
    ".": "./dist-cjs/src/services/mcp-integration.js",
    "./checkpoint-manager": "./dist-cjs/src/services/checkpoint-manager.js",
    "./in-process-mcp": "./dist-cjs/src/server/in-process-mcp.js",
    "./cli": "./dist-cjs/src/main.js"
  },
  "files": [
    "bin/",
    "dist-cjs/",
    ".claude-flow/",
    ".claude-plugin/",
    ".claude/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist-cjs/src/main.js",
    "test": "node --test src/**/*.test.ts 2>/dev/null || echo 'No tests found'"
  },
  "keywords": [
    "claude",
    "ai",
    "agent",
    "orchestration",
    "mcp",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
