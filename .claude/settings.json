{
  "version": "1.0.0",
  "model": "claude-opus-4-6",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(source:*)",
      "Bash(export:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(pwd)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(sort:*)",
      "Bash(tree:*)",
      "Bash(diff:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout -- :*)"
    ]
  },
  "env": {
    "NODE_ENV": "development"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\\(.session_id // \"unknown\" | .[0:8])] \\(.tool_input.command // \"\")\"' >> ~/.claude/bash-log.txt 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [],
    "Stop": [],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -d /home/user/h2568/node_modules ] || (cd /home/user/h2568 && npm install --silent 2>/dev/null) || true"
          }
        ]
      }
    ]
  }
}
